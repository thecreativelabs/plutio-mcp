# Plutio OAuth2 credentials — get them from Plutio → Settings → API Manager → Create Connection
PLUTIO_CLIENT_ID=
PLUTIO_CLIENT_SECRET=

# The business/workspace slug your OAuth client targets (e.g. "creativelabs" if your
# workspace URL is creativelabs.plutio.com). Optional if your OAuth client is
# associated with exactly one business — the server auto-detects it from the token
# response. REQUIRED when the client has access to multiple businesses.
# PLUTIO_BUSINESS=

# Optional: override the API base URL (defaults to https://api.plutio.com/v1.11)
# PLUTIO_API_BASE=https://api.plutio.com/v1.11

# Optional: override the OAuth token URL (defaults to PLUTIO_API_BASE + /oauth/token)
# PLUTIO_OAUTH_URL=

# Safety — when true, the server only exposes read-only tools (list/get/search).
# Set to "false" to enable create/update/delete/archive/bulk actions.
# Default: true
PLUTIO_READ_ONLY=true

# Rate limit configuration. Plutio allows 1000 req/hr per key by default.
# Leave these alone unless you have a higher tier.
# PLUTIO_MAX_REQUESTS_PER_HOUR=1000

# Log level for the MCP server (error|warn|info|debug). Default: info.
# PLUTIO_LOG_LEVEL=info

# ─── HTTP transport (v0.7.0+) ────────────────────────────────────────────────
# Set to "true" to run as an HTTP server instead of stdio. Required for ChatGPT,
# web-based MCP clients, and remote deployments. Stdio is the default for local
# desktop clients (Claude Desktop, Cursor, Zed, Windsurf, etc.)
# PLUTIO_MCP_HTTP=false

# HTTP port. Default: 8080.
# PLUTIO_MCP_HTTP_PORT=8080

# HTTP host. Default: 127.0.0.1 (localhost-only; safer). Set to "0.0.0.0" to
# accept remote connections (e.g. behind ngrok or a reverse proxy).
# PLUTIO_MCP_HTTP_HOST=127.0.0.1

# Optional bearer token to gate HTTP requests. If set, every request must send
# `Authorization: Bearer <token>`. STRONGLY recommended if you expose the server
# publicly (ngrok, Cloudflare Tunnel, etc.).
# PLUTIO_MCP_AUTH_TOKEN=

# ─── User preset directory (v0.10.1+) ───────────────────────────────────────
# Path to a directory containing your private contract/proposal preset JSON
# files. Loaded alongside the built-in presets shipped with this package. Use
# this when you've extracted your own Plutio templates via plutio_template_to_preset
# and want them available to plutio_{contract,proposal}_from_preset without
# committing them to the public repo.
#
# Expected layout:
#   $PLUTIO_USER_PRESETS_DIR/
#     contracts/
#       my-template.json
#     proposals/
#       my-template.json
#
# A user preset whose `slug` matches a built-in shadows the built-in.
# PLUTIO_USER_PRESETS_DIR=/Users/me/plutio-templates
