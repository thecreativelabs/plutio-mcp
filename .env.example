# Plutio OAuth2 credentials — get them from Plutio → Settings → API Manager → Create Connection
PLUTIO_CLIENT_ID=
PLUTIO_CLIENT_SECRET=

# Optional: override the API base URL (defaults to https://api.plutio.com/v1.11)
# PLUTIO_API_BASE=https://api.plutio.com/v1.11

# Optional: override the OAuth token URL (defaults to PLUTIO_API_BASE + /oauth/token)
# PLUTIO_OAUTH_URL=

# Safety — when true, the server only exposes read-only tools (list/get/search).
# Set to "false" to enable create/update/delete/archive/bulk actions.
# Default: true
PLUTIO_READ_ONLY=true

# Rate limit configuration. Plutio allows 1000 req/hr per key by default.
# Leave these alone unless you have a higher tier.
# PLUTIO_MAX_REQUESTS_PER_HOUR=1000

# Log level for the MCP server (error|warn|info|debug). Default: info.
# PLUTIO_LOG_LEVEL=info
